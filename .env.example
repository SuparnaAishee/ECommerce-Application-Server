# ---- App ----
NODE_ENV=development
PORT=5000

# ---- Database ----
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# ---- Auth ----
BCRYPT_SALT_ROUND=12

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_ACCESS_SECRET=replace-with-32+-char-base64-secret
JWT_ACCESS_EXPIRES_IN=10d
JWT_REFRESH_SECRET=replace-with-32+-char-base64-secret
JWT_REFRESH_EXPIRES_IN=30d
RESET_PASSWORD_SECRET=replace-with-32+-char-base64-secret
RESET_PASSWORD_EXPIRES_IN=5m

# ---- URLs ----
CLIENT_BASE_URL=http://localhost:3000
SERVER_BASE_URL=http://localhost:5000

# Comma-separated allowlist of CORS origins. Falls back to CLIENT_BASE_URL if unset.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Email (optional, for password reset / notifications) ----
SENDER_EMAIL=you@example.com
APP_PASSWORD=your-app-password

# ---- Payment (Aamarpay) ----
PAYMENT_URL=https://sandbox.aamarpay.com/request.php
PAYMENT_VERIFY_URL=https://sandbox.aamarpay.com/api/v1/trxcheck/request.php
STORE_ID=aamarpaytest
SIGNATURE_KEY=your-aamarpay-signature-key

# ---- AI Shopping Assistant (n8n + Gemini) ----
# n8n self-hosted via docker-compose.yml. The backend forwards
# /api/v1/chat requests to the n8n webhook below.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/chat
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# Get a free key at https://aistudio.google.com (used by n8n's Gemini node).
# Plug it into n8n via env (docker-compose pipes it through) or as a
# workflow credential.
GEMINI_API_KEY=your-gemini-api-key
